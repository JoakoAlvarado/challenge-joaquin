{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ChallengeApiDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "ChallengeApiSuperSecretKey2026!MustBe32CharsMin",
    "Issuer": "ChallengeApi",
    "Audience": "ChallengeApiUsers",
    "ExpirationHours": "8"
  },
  "ExternalApis": {
    "HoroscopeApiUrl": "https://newastro.vercel.app/"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/challengeapi-.log",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}